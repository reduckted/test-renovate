{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": ["group:all"],
    "packageRules": [
        {
            "matchDepTypes": ["dependencies"],
            "postUpgradeTasks": {
                "commands": ["node ./two.js"],
                "fileFilters": ["two.txt"],
                "executionMode": "update"
            }
        },
        {
            "matchDepTypes": ["devDependencies"],
            "postUpgradeTasks": {
                "commands": ["node ./one.js"],
                "fileFilters": ["one.txt"],
                "executionMode": "update"
            }
        },
        {
            "matchFileNames": ["**/Directory.Packages.Net80.props"],
            "matchDepTypes": ["AspNet.Security.OAuth.GitHub"],
            "allowedVersions": "/^8\\..+$/"
        },
        {
            "matchFileNames": ["**/Directory.Packages.Net90.props"],
            "matchDepTypes": ["AspNet.Security.OAuth.GitHub"],
            "allowedVersions": "/^9\\..+$/"
        }
    ]
}
